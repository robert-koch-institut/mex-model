{
    "$$target": "/mex/model/entities/extracted-location#/identifier",
    "$id": "https://mex.rki.de/mex/model/entities/extracted-location",
    "$schema": "http://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "description": "A spatial region or named place.",
    "properties": {
        "geoNamesId": {
            "default": [],
            "description": "Identifier in the GeoNames geographical database.",
            "exactMatch": [
                "https://www.wikidata.org/wiki/Property:P1566"
            ],
            "items": {
                "format": "uri",
                "pattern": "^http://www\\.geonames\\.org/[0-9]{7}$",
                "type": "string"
            },
            "type": "array"
        },
        "identifier": {
            "$ref": "/mex/model/fields/identifier",
            "closeMatch": [
                "http://purl.org/dc/elements/1.1/identifier"
            ],
            "description": "An unambiguous reference to the resource within a given context. Persistent identifiers should be provided as HTTP URIs ([DCT, 2020-01-20](http://dublincore.org/specifications/dublin-core/dcmi-terms/2020-01-20/)).",
            "readOnly": true
        },
        "identifierInPrimarySource": {
            "description": "The identifier of the item used in the primary source.",
            "examples": [
                "123456",
                "item-501",
                "D7/x4/zz.final3"
            ],
            "maxLength": 1000,
            "minLength": 1,
            "pattern": "^[^\\n\\r]+$",
            "type": "string"
        },
        "name": {
            "closeMatch": [
                "https://schema.org/name"
            ],
            "description": "Name of the location.",
            "items": {
                "$ref": "/mex/model/fields/text"
            },
            "minItems": 1,
            "type": "array"
        },
        "stableTargetId": {
            "$ref": "/mex/model/entities/merged-location#/identifier",
            "description": "The identifier of the merged item that this extracted item belongs to.",
            "readOnly": true
        },
        "wikidataId": {
            "default": [],
            "description": "Identifier from Wikidata.",
            "items": {
                "examples": [
                    "http://www.wikidata.org/entity/Q679041",
                    "http://www.wikidata.org/entity/Q918501",
                    "http://www.wikidata.org/entity/Q491566"
                ],
                "format": "uri",
                "pattern": "^http://www\\.wikidata\\.org/entity/[PQ0-9]{2,64}$",
                "type": "string"
            },
            "type": "array"
        }
    },
    "required": [
        "name",
        "identifier",
        "identifierInPrimarySource",
        "stableTargetId"
    ],
    "title": "ExtractedLocation",
    "type": "object"
}
