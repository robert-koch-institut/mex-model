{
    "$$target": "/mex/model/entities/extracted-resource#/identifier",
    "$id": "https://mex.rki.de/mex/model/entities/extracted-resource",
    "$schema": "http://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "closeMatch": [
        "http://www.w3.org/ns/dcat#Dataset"
    ],
    "description": "A defined piece of information or collection of information on Public Health, that has been generated as part of a (research) activity at the RKI or to comply with a (federal) law or regulation that applies to the RKI.",
    "properties": {
        "accessPlatform": {
            "closeMatch": [
                "http://www.w3.org/ns/dcat#accessService"
            ],
            "default": [],
            "description": "A platform from which the resource can be accessed.",
            "items": {
                "$ref": "/mex/model/entities/merged-access-platform#/identifier"
            },
            "type": "array"
        },
        "accessRestriction": {
            "$ref": "/mex/model/entities/concept#/identifier",
            "closeMatch": [
                "http://purl.org/dc/terms/accessRights"
            ],
            "description": "Indicates how access to the resource is restricted.",
            "examples": [
                "https://mex.rki.de/item/access-restriction-1"
            ],
            "useScheme": "https://mex.rki.de/item/access-restriction"
        },
        "accrualPeriodicity": {
            "anyOf": [
                {
                    "$ref": "/mex/model/entities/concept#/identifier",
                    "examples": [
                        "https://mex.rki.de/item/frequency-1"
                    ],
                    "useScheme": "https://mex.rki.de/item/frequency"
                },
                {
                    "type": "null"
                }
            ],
            "closeMatch": [
                "http://purl.org/dc/terms/accrualPeriodicity"
            ],
            "default": null,
            "description": "The frequency with which items are added to a collection."
        },
        "alternativeTitle": {
            "closeMatch": [
                "http://purl.org/dc/terms/alternative"
            ],
            "default": [],
            "description": "An alternative name for the resource.",
            "items": {
                "$ref": "/mex/model/fields/text"
            },
            "type": "array"
        },
        "analytics": {
            "closeMatch": [
                "http://healthdataportal.eu/ns/health#analytics"
            ],
            "default": [],
            "description": "An analytics distribution of the dataset.",
            "items": {
                "$ref": "/mex/model/entities/merged-distribution#/identifier"
            },
            "type": "array"
        },
        "anonymizationPseudonymization": {
            "default": [],
            "description": "Indicates whether the data has been anonymized and/or pseudonymized.",
            "items": {
                "$ref": "/mex/model/entities/concept#/identifier",
                "examples": [
                    "https://mex.rki.de/item/anonymization-pseudonymization-1"
                ],
                "useScheme": "https://mex.rki.de/item/anonymization-pseudonymization"
            },
            "type": "array"
        },
        "conformsTo": {
            "closeMatch": [
                "http://purl.org/dc/terms/conformsTo"
            ],
            "default": [],
            "description": "Standards used in the creation, analysis or transmission of the resource.",
            "items": {
                "examples": [
                    "FHIR",
                    "LOINC",
                    "SNOMED",
                    "ICD-10"
                ],
                "type": "string"
            },
            "type": "array"
        },
        "contact": {
            "closeMatch": [
                "http://www.w3.org/ns/dcat#contactPoint"
            ],
            "description": "An agent that serves as a contact for the resource.",
            "items": {
                "anyOf": [
                    {
                        "$ref": "/mex/model/entities/merged-organizational-unit#/identifier"
                    },
                    {
                        "$ref": "/mex/model/entities/merged-contact-point#/identifier"
                    }
                ]
            },
            "minItems": 1,
            "type": "array"
        },
        "contributingUnit": {
            "closeMatch": [
                "http://purl.org/dc/terms/contributor"
            ],
            "default": [],
            "description": "An organizational unit of RKI, that is contributing to the resource.",
            "items": {
                "$ref": "/mex/model/entities/merged-organizational-unit#/identifier"
            },
            "type": "array"
        },
        "contributor": {
            "closeMatch": [
                "http://purl.org/dc/terms/contributor"
            ],
            "default": [],
            "description": "A person involved in the creation of the resource.",
            "items": {
                "$ref": "/mex/model/entities/merged-person#/identifier"
            },
            "type": "array"
        },
        "created": {
            "anyOf": [
                {
                    "$comment": "year_month_day_time",
                    "examples": [
                        "2022-09-30T20:48:35Z"
                    ],
                    "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[0-1][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$",
                    "type": "string"
                },
                {
                    "$comment": "year_month_day",
                    "examples": [
                        "2014-08-24"
                    ],
                    "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])$",
                    "type": "string"
                },
                {
                    "$comment": "year_month",
                    "examples": [
                        "2019-03"
                    ],
                    "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])$",
                    "type": "string"
                },
                {
                    "$comment": "year",
                    "examples": [
                        "2024"
                    ],
                    "pattern": "^[0-9]{4}$",
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "closeMatch": [
                "http://purl.org/dc/terms/created"
            ],
            "default": null,
            "description": "Date of creation of the resource"
        },
        "creator": {
            "closeMatch": [
                "http://purl.org/dc/terms/creator"
            ],
            "default": [],
            "description": "A person responsible for making the resource.",
            "items": {
                "$ref": "/mex/model/entities/merged-person#/identifier"
            },
            "type": "array"
        },
        "description": {
            "closeMatch": [
                "http://purl.org/dc/terms/description"
            ],
            "default": [],
            "description": "A text describing the nature of the resource.",
            "items": {
                "$ref": "/mex/model/fields/text"
            },
            "type": "array"
        },
        "distribution": {
            "default": [],
            "description": "An available distribution of the resource",
            "items": {
                "$ref": "/mex/model/entities/merged-distribution#/identifier"
            },
            "type": "array"
        },
        "documentation": {
            "closeMatch": [
                "http://purl.org/dc/terms/isReferencedBy"
            ],
            "default": [],
            "description": "A link to a document documenting the resource.",
            "items": {
                "$ref": "/mex/model/fields/link"
            },
            "type": "array"
        },
        "doi": {
            "$comment": "Only applicable for published datasets.",
            "anyOf": [
                {
                    "examples": [
                        "https://doi.org/10.1007/978-1-0716-2441-8_7",
                        "https://doi.org/10.2807/1560-7917.ES.2022.27.46.2200849",
                        "https://doi.org/10.3389/fmicb.2022.868887",
                        "http://dx.doi.org/10.25646/5147",
                        "https://doi.org/10.1016/j.vaccine.2022.11.065"
                    ],
                    "pattern": "^https?://(?:dx\\.)?doi\\.org/[0-9]{2}\\.[0-9]{4,9}[-_.;()/:A-Za-z0-9]{0,256}$",
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "default": null,
            "description": "The Digital Object Identifier (DOI) of the resource."
        },
        "end": {
            "anyOf": [
                {
                    "$comment": "year_month_day_time",
                    "examples": [
                        "2022-09-30T20:48:35Z"
                    ],
                    "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[0-1][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$",
                    "type": "string"
                },
                {
                    "$comment": "year_month_day",
                    "examples": [
                        "2014-08-24"
                    ],
                    "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])$",
                    "type": "string"
                },
                {
                    "$comment": "year_month",
                    "examples": [
                        "2019-03"
                    ],
                    "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])$",
                    "type": "string"
                },
                {
                    "$comment": "year",
                    "examples": [
                        "2024"
                    ],
                    "pattern": "^[0-9]{4}$",
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "closeMatch": [
                "http://www.w3.org/ns/dcat#endDate"
            ],
            "default": null,
            "description": "End date of the temporal coverage of the resource.",
            "maxItems": 1
        },
        "externalPartner": {
            "closeMatch": [
                "http://purl.org/dc/terms/contributor"
            ],
            "default": [],
            "description": "An external organization that is somehow involved in the creation of the resource.",
            "items": {
                "$ref": "/mex/model/entities/merged-organization#/identifier"
            },
            "type": "array"
        },
        "hadPrimarySource": {
            "$ref": "/mex/model/entities/merged-primary-source#/identifier",
            "closeMatch": [
                "http://www.w3.org/ns/prov#hadPrimarySource"
            ],
            "description": "A primary source for a topic refers to something produced by some agent with direct experience and knowledge about the topic, at the time of the topic's study, without benefit from hindsight. Because of the directness of primary sources, they 'speak for themselves' in ways that cannot be captured through the filter of secondary sources. As such, it is important for secondary sources to reference those primary sources from which they were derived, so that their reliability can be investigated. A primary source relation is a particular case of derivation of secondary materials from their primary sources. It is recognized that the determination of primary sources can be up to interpretation, and should be done according to conventions accepted within the application's domain ([PROV-O, 2013-04-30 ](http://www.w3.org/TR/2013/REC-prov-o-20130430/))."
        },
        "hasCodeValues": {
            "closeMatch": [
                "http://healthdataportal.eu/ns/health#hasCodeValues"
            ],
            "default": [],
            "description": "The code values of the respective coding systems that are applied to the dataset, for example code value 'U07.1' as used in the coding system 'ICD-10'.",
            "items": {
                "$ref": "/mex/model/fields/text"
            },
            "type": "array"
        },
        "hasCodingSystem": {
            "closeMatch": [
                "http://healthdataportal.eu/ns/health#hasCodingSystem"
            ],
            "default": [],
            "description": "Coding systems in use (i.e. ICD-10, SNOMED-CT).",
            "items": {
                "$ref": "/mex/model/entities/concept#/identifier",
                "examples": [
                    "https://mex.rki.de/item/coding-system-1"
                ],
                "useScheme": "https://mex.rki.de/item/coding-system"
            },
            "type": "array"
        },
        "hasLegalBasis": {
            "closeMatch": [
                "https://w3id.org/dpv#hasLegalBasis"
            ],
            "default": [],
            "description": "The legal basis used to justify processing of personal data. Legal basis (plural: legal bases) are defined by legislations and regulations, whose applicability is usually restricted to specific jurisdictions which can be represented using dpv:hasJurisdiction or dpv:hasLaw. Legal basis can be used without such declarations, e.g. 'Consent', however their interpretation will require association with a law, e.g. 'EU GDPR'.",
            "items": {
                "anyOf": [
                    {
                        "$ref": "/mex/model/fields/text"
                    },
                    {
                        "$ref": "/mex/model/fields/link"
                    }
                ]
            },
            "type": "array"
        },
        "hasPersonalData": {
            "anyOf": [
                {
                    "$ref": "/mex/model/entities/concept#/identifier",
                    "examples": [
                        "https://mex.rki.de/item/personal-data-1"
                    ],
                    "useScheme": "https://mex.rki.de/item/personal-data"
                },
                {
                    "type": "null"
                }
            ],
            "closeMatch": [
                "https://w3id.org/dpv#hasPersonalData"
            ],
            "default": null,
            "description": "Indicates, if a resource contains data directly or indirectly associated or related to an individual."
        },
        "hasPurpose": {
            "closeMatch": [
                "https://w3id.org/dpv#hasPurpose"
            ],
            "default": [],
            "description": "A controlled list of types of purposes for which the data was originally collected.",
            "items": {
                "$ref": "/mex/model/entities/concept#/identifier",
                "useScheme": "https://mex.rki.de/item/purpose"
            },
            "type": "array"
        },
        "hasPurposeDescription": {
            "closeMatch": [
                "https://w3id.org/dpv#hasPurpose"
            ],
            "default": [],
            "description": "A free text statement of the purpose of the processing of data or personal data.",
            "items": {
                "$ref": "/mex/model/fields/text"
            },
            "type": "array"
        },
        "hasVersion": {
            "closeMatch": [
                "http://www.w3.org/ns/dcat#hasVersion"
            ],
            "default": [],
            "description": "A related Resource that is a version, edition, or adaptation of the described Resource.",
            "items": {
                "$ref": "/mex/model/entities/merged-resource#/identifier"
            },
            "type": "array"
        },
        "healthCategory": {
            "closeMatch": [
                "http://healthdataportal.eu/ns/health#healthCategory"
            ],
            "default": [],
            "description": "The category of electronic data for secondary use to which this resource belongs, as described in Article 51 of the Commission Regulation on the European Health Data Space.",
            "items": {
                "$ref": "/mex/model/entities/concept#/identifier",
                "examples": [
                    "https://mex.rki.de/item/health-category-1"
                ],
                "useScheme": "https://mex.rki.de/item/health-category"
            },
            "type": "array"
        },
        "icd10code": {
            "default": [],
            "description": "A concept from ICD-10.",
            "items": {
                "type": "string"
            },
            "type": "array"
        },
        "identifier": {
            "$ref": "/mex/model/fields/identifier",
            "closeMatch": [
                "http://purl.org/dc/elements/1.1/identifier"
            ],
            "description": "An unambiguous reference to the resource within a given context. Persistent identifiers should be provided as HTTP URIs ([DCT, 2020-01-20](http://dublincore.org/specifications/dublin-core/dcmi-terms/2020-01-20/)).",
            "readOnly": true
        },
        "identifierInPrimarySource": {
            "description": "The identifier of the item used in the primary source.",
            "examples": [
                "123456",
                "item-501",
                "D7/x4/zz.final3"
            ],
            "maxLength": 1000,
            "minLength": 1,
            "pattern": "^[^\\n\\r]+$",
            "type": "string"
        },
        "inSeries": {
            "closeMatch": [
                "https://www.w3.org/ns/dcat#inSeries"
            ],
            "default": [],
            "description": "A resource series of which the resource is part.",
            "items": {
                "$ref": "/mex/model/entities/merged-resource-series#/identifier"
            },
            "type": "array"
        },
        "instrumentToolOrApparatus": {
            "default": [],
            "description": "Instrument, tool, or apparatus used in the research, analysis, observation, or processing of the object that is the subject of this resource.",
            "items": {
                "$ref": "/mex/model/fields/text"
            },
            "type": "array"
        },
        "isPartOf": {
            "closeMatch": [
                "http://purl.org/dc/terms/isPartOf"
            ],
            "default": [],
            "description": "A related resource, in which the described resource is physically or logically included.",
            "items": {
                "$ref": "/mex/model/entities/merged-resource#/identifier"
            },
            "type": "array"
        },
        "keyword": {
            "closeMatch": [
                "http://www.w3.org/ns/dcat#keyword"
            ],
            "description": "A keyword or tag describing the resource.",
            "items": {
                "anyOf": [
                    {
                        "$ref": "/mex/model/fields/text"
                    },
                    {
                        "$ref": "/mex/model/fields/link"
                    }
                ]
            },
            "minItems": 1,
            "type": "array"
        },
        "landingPage": {
            "closeMatch": [
                "https://www.w3.org/ns/dcat#landingPage"
            ],
            "default": [],
            "description": "A web page that provides access to the resource, its distributions and/or additional information.",
            "items": {
                "$ref": "/mex/model/fields/link"
            },
            "type": "array"
        },
        "language": {
            "closeMatch": [
                "http://purl.org/dc/terms/language"
            ],
            "default": [],
            "description": "A language of the resource.",
            "items": {
                "$ref": "/mex/model/entities/concept#/identifier",
                "examples": [
                    "https://mex.rki.de/item/language-1"
                ],
                "useScheme": "https://mex.rki.de/item/language"
            },
            "type": "array"
        },
        "license": {
            "$comment": "Information about licenses SHOULD be provided on the level of `dcat:Distribution`. Information about licenses MAY be provided for a `mex:Resource` in addition, but not instead, of the information provided for the distributions of that resource ([DCAT, 2020-02-04](https://www.w3.org/TR/2020/REC-vocab-dcat-2-20200204/)).",
            "anyOf": [
                {
                    "$ref": "/mex/model/entities/concept#/identifier",
                    "examples": [
                        "https://mex.rki.de/item/license-1"
                    ],
                    "useScheme": "https://mex.rki.de/item/license"
                },
                {
                    "type": "null"
                }
            ],
            "closeMatch": [
                "http://purl.org/dc/terms/license"
            ],
            "default": null,
            "description": "A legal document giving official permission to do something with the resource."
        },
        "loincId": {
            "default": [],
            "description": "A concept from LOINC.",
            "items": {
                "examples": [
                    "https://loinc.org/95209-3",
                    "https://loinc.org/LA26211-5",
                    "https://loinc.org/96766-1"
                ],
                "format": "uri",
                "pattern": "^https://loinc\\.org/[-A-Za-z0-9]{2,64}$",
                "type": "string"
            },
            "type": "array"
        },
        "maxTypicalAge": {
            "anyOf": [
                {
                    "examples": [
                        "99",
                        "21"
                    ],
                    "type": "integer"
                },
                {
                    "type": "null"
                }
            ],
            "closeMatch": [
                "http://healthdataportal.eu/ns/health#maxtypicalage"
            ],
            "default": null,
            "description": "Specifies the maximum age of the population within the data collection, expressed in years."
        },
        "meshId": {
            "default": [],
            "description": "A concept from MeSH.",
            "items": {
                "examples": [
                    "http://id.nlm.nih.gov/mesh/D001604",
                    "http://id.nlm.nih.gov/mesh/T025130",
                    "http://id.nlm.nih.gov/mesh/D007717"
                ],
                "format": "uri",
                "pattern": "^http://id\\.nlm\\.nih\\.gov/mesh/[A-Z0-9]{2,64}$",
                "type": "string"
            },
            "type": "array"
        },
        "method": {
            "default": [],
            "description": "Method used in the research, analysis, observation or processing of the object that is subject to the resource.",
            "items": {
                "$ref": "/mex/model/fields/text"
            },
            "type": "array"
        },
        "methodDescription": {
            "closeMatch": [
                "http://purl.org/dc/terms/description"
            ],
            "default": [],
            "description": "The description of the method, that was used to research, analysis, observation or processing of the object that was subject to the resource.",
            "items": {
                "$ref": "/mex/model/fields/text"
            },
            "type": "array"
        },
        "minTypicalAge": {
            "anyOf": [
                {
                    "examples": [
                        "0",
                        "18"
                    ],
                    "type": "integer"
                },
                {
                    "type": "null"
                }
            ],
            "closeMatch": [
                "http://healthdataportal.eu/ns/health#mintypicalage"
            ],
            "default": null,
            "description": "Specifies the minimum age of the population within the data collection, expressed in years."
        },
        "modified": {
            "anyOf": [
                {
                    "$comment": "year_month_day_time",
                    "examples": [
                        "2022-09-30T20:48:35Z"
                    ],
                    "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[0-1][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$",
                    "type": "string"
                },
                {
                    "$comment": "year_month_day",
                    "examples": [
                        "2014-08-24"
                    ],
                    "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])$",
                    "type": "string"
                },
                {
                    "$comment": "year_month",
                    "examples": [
                        "2019-03"
                    ],
                    "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])$",
                    "type": "string"
                },
                {
                    "$comment": "year",
                    "examples": [
                        "2024"
                    ],
                    "pattern": "^[0-9]{4}$",
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "closeMatch": [
                "http://purl.org/dc/terms/modified"
            ],
            "default": null,
            "description": "Date on which the resource was changed."
        },
        "numberOfRecords": {
            "anyOf": [
                {
                    "type": "integer"
                },
                {
                    "type": "null"
                }
            ],
            "closeMatch": [
                "http://healthdataportal.eu/ns/health#numberOfRecords"
            ],
            "default": null,
            "description": "The total number of records in the dataset. The number reflects the total data entries (e.g., consultations, prescriptions, lab results, hospital admissions) according to the dataset's content."
        },
        "numberOfUniqueIndividuals": {
            "anyOf": [
                {
                    "type": "integer"
                },
                {
                    "type": "null"
                }
            ],
            "closeMatch": [
                "http://healthdataportal.eu/ns/health#numberOfUniqueIndividuals"
            ],
            "default": null,
            "description": "The number of records for unique individuals represented in the dataset."
        },
        "populationCoverage": {
            "closeMatch": [
                "http://healthdataportal.eu/ns/health#populationcoverage"
            ],
            "default": [],
            "description": "The type of population common to all subjects of the data collection.",
            "items": {
                "$ref": "/mex/model/fields/text"
            },
            "type": "array"
        },
        "provenance": {
            "closeMatch": [
                "http://purl.org/dc/terms/provenance",
                "http://healthdataportal.eu/ns/health#provenance"
            ],
            "default": [],
            "description": "A statement about the lineage of a Dataset. Information about how the data was collected, including methodologies, tools, and protocols used.",
            "items": {
                "$ref": "/mex/model/fields/text"
            },
            "type": "array"
        },
        "publication": {
            "closeMatch": [
                "http://purl.org/dc/terms/isReferencedBy"
            ],
            "default": [],
            "description": "A publication that deals with the research, analysis, observation or processing of the object that was subject to the resource, e.g. a research paper.",
            "items": {
                "$ref": "/mex/model/entities/merged-bibliographic-resource#/identifier"
            },
            "type": "array"
        },
        "publisher": {
            "default": [],
